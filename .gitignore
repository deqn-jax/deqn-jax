# Project-specific: archive old experimental configs, track canonical ones.
configs/archive/
configs/_diag_*.yaml
configs/dgx_*.yaml
# Experiment scripts and working notes. Checked-in exceptions below.
scripts/*
!scripts/make_plots.py
!scripts/gen_config_reference.py
!scripts/check_module_graph.py
!scripts/sweep_disaster_second_order.py
!scripts/sweep_disaster_kf_validation.py
!scripts/aio_head_to_head.py
!scripts/run_sweep_in_container.sh
!scripts/fetch_sweep_results.sh
dynare/
PLAN.md
docs/session_log.md
docs/session_state_*.md
docs/design_notes.md
irf_results/

# Claude Code: ignore everything except shared project tooling
# (hooks, settings, prompt artifacts). Per-user settings stay local
# via .claude/settings.local.json.
.claude/*
!.claude/settings.json
!.claude/hooks/
!.claude/hooks/**
!.claude/ralph_refactor_prompt.md
!.claude/ralph_typing_prompt.md
!.claude/ralph_disaster_diag_prompt.md
!.claude/ralph_disaster_so_sweep_prompt.md

# Docs (PDFs are binary, keep .tex in version control)
docs/*.pdf

# mkdocs build output (regenerated; only docs/site/ source is tracked)
/site/

# Plot outputs (regenerated by scripts/make_plots.py)
/plots/

# Jupyter auto-save folders
.ipynb_checkpoints/

# Figures written by model cycle_hooks during training (regenerated)
/figures/
examples/figures/

# JetBrains Junie local AI state (tool-local, like .idea/)
.junie/

# LaTeX build artifacts (keep .tex; .pdf already ignored above)
docs/*.aux
docs/*.log
docs/*.out
docs/*.toc
docs/*.synctex.gz
